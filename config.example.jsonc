{
  // Protocol configurations
  "protocols": [
    {
      // Milky protocol (primary)
      "name": "milky",
      "enabled": true,
      "priority": 1,
      "connectionType": "websocket",
      "mockSendMessage": false,
      "connection": {
        "url": "ws://192.168.50.97:3010/event",
        "apiUrl": "http://192.168.50.97:3010/api",
        "accessToken": "your_access_token_here"
      },
      "reconnect": {
        "enabled": true,
        "maxRetries": 10,
        "backoff": "exponential",
        "initialDelay": 1000,
        "maxDelay": 30000
      }
    },
    {
      // OneBot11 protocol (fallback)
      "name": "onebot11",
      "enabled": true,
      "priority": 2,
      "connectionType": "websocket",
      "connection": {
        "url": "ws://192.168.50.97:3001/event",
        "apiUrl": "http://192.168.50.97:3001/api",
        "accessToken": "your_access_token_here"
      },
      "reconnect": {
        "enabled": true,
        "maxRetries": 10,
        "backoff": "exponential",
        "initialDelay": 1000,
        "maxDelay": 30000
      }
    },
    {
      // Discord protocol
      // Requires a Discord Bot application: https://discord.com/developers/applications
      // Enable Privileged Intents: Message Content Intent, Server Members Intent
      "name": "discord",
      "enabled": false,
      "priority": 3,
      "connectionType": "discord",
      "mockSendMessage": false,
      "connection": {
        "url": "",
        "apiUrl": "",
        "accessToken": "YOUR_DISCORD_BOT_TOKEN"
      },
      "discord": {
        "intents": [
          "Guilds",
          "GuildMessages",
          "MessageContent",
          "DirectMessages",
          "GuildMembers"
        ],
        "guildId": ""
      },
      // Per-protocol owner/admin overrides (Discord user IDs differ from QQ IDs)
      "owner": "YOUR_DISCORD_USER_ID",
      "admins": [],
      "reconnect": {
        "enabled": true,
        "maxRetries": 10,
        "backoff": "exponential",
        "initialDelay": 1000,
        "maxDelay": 30000
      }
    }
  ],
  // API configuration
  "api": {
    "strategy": "priority",
    "preferredProtocol": "milky"
  },
  // Event deduplication configuration
  "events": {
    "deduplication": {
      "enabled": true,
      "strategy": "first-received",
      "window": 5000
    }
  },
  // LAN WebSocket relay (optional). Independent of Agent Cluster.
  // - host: listens for clients; set relayInboundFromIm to fan out IM messages to clients.
  // - client: does not open QQ/Discord connections; outbound replies go to host via relay_action.
  // LAN WebSocket relay (Phase 2 dispatch model).
  //
  // Same config.d/ deploys to host and client; only `instanceRole` and the
  // role-specific fields differ between machines. Token must match across
  // all peers (rotate everywhere simultaneously).
  //
  // Phase 2 model:
  //   1. Client is silent unless host explicitly dispatches via `/lan @<id>`.
  //   2. Dispatch is routed to a specific client by `clientId` (no broadcast).
  //   3. Client replies / sendToUser go back through host → original IM platform.
  //   4. zhihu/wechat plugins and StaticServer backend modules can be skipped per
  //      role via the lists below (PluginInitializer + bootstrap apply them BEFORE
  //      plugin instantiation where applicable).
  "lanRelay": {
    "enabled": false,
    "instanceRole": "host", // 'host' | 'client'
    "token": "change_me_lan_relay_token", // shared secret — generate with: openssl rand -hex 24
    // ── Host-only fields ──────────────────────────────────────────────
    "listenHost": "0.0.0.0",
    "listenPort": 47123,
    // Fallback target when a client calls runtime.sendToUser() without a
    // dispatch origin (e.g. cron-driven autonomous tasks). Required if you
    // want client-initiated outbound messages.
    "defaultReplyTarget": {
      "protocol": "milky",
      "chatType": "private",
      "userId": "123456789"
    },
    // ── Client-only fields (required when instanceRole=client) ────────
    "connectUrl": "ws://192.168.50.209:47123/lan-relay",
    "clientId": "workstation-A", // unique across connected clients; duplicates rejected
    "clientLabel": "MacBook Pro M3", // optional human-readable label for /lan list
    "publicAddress": "192.168.50.42", // LAN-reachable IP of THIS client (no auto-detection)
    // ── Role-scoped service/plugin filter ─────────────────────────────
    // The same config.d/ runs on host and client. The matching role's
    // disable lists are applied at PluginInitializer / bootstrap time.
    "host": {
      "disabledPlugins": [],
      "disabledServices": []
    },
    "client": {
      // zhihu / wechat are data-collection plugins that should only run on
      // the host (single-source-of-truth). Add others as needed.
      "disabledPlugins": [
        "zhihuFeed",
        "wechatIngest"
      ],
      "disabledServices": [],
      // Optional: omit disk file routes on this client (host holds shared files). See createBackends registry for ids.
      "disabledStaticBackends": [
        "files",
        "output"
      ]
    }
  },
  // Bot configuration
  "bot": {
    "selfId": null,
    // Bot owner: highest permission level, can use all commands (global default, typically QQ ID)
    "owner": "123123",
    // Bot admins: user IDs that have admin permission level
    // These users can adjust bot behavior and trigger special commands
    "admins": [
      "123123",
      "123123"
    ]
  },
  // Static file server configuration (optional)
  "staticServer": {
    "port": 8888,
    "host": "192.168.50.173",
    "root": "./output"
  },
  // File read service configuration (optional)
  "fileReadService": {
    "root": "./",
    "filterPaths": [
      "node_modules",
      "output",
      "data",
      "logs",
      "config.json"
    ],
    "filterExtensions": [
      "jpg",
      "jpeg",
      "png",
      "gif",
      "bmp",
      "webp"
    ]
  },
  // Plugin configuration
  // Plugins must be placed in src/plugins/ directory
  "plugins": {
    "list": [
      // MessageTriggerPlugin: unified reply trigger. Provider-name prefix always triggers; a lightweight LLM check (default provider) confirms invite before full reply.
      // {
      //   "name": "messageTrigger",
      //   "enabled": true,
      //   "config": { "wakeWords": [] }
      // },
      // Whitelist plugin: access control. Use "groups" for per-group limited capabilities (reply, command, proactive, reaction, subagent, echo).
      // Example: group 672372860 only proactive + @bot reply (no command, reaction, echo, subagent).
      {
        "name": "whitelist",
        "enabled": true,
        "config": {
          "userIds": [
            "123456789"
          ],
          "groups": [
            {
              "id": "1111",
              "capabilities": [
                "reply",
                "proactive"
              ]
            }
            // Full access: omit capabilities or use "capabilities": []
            // { "id": "123456789" }
          ]
        }
      },
      // Message Operation Plugin - handles reactions on messages
      {
        "name": "messageOperation",
        "enabled": true,
        "config": {
          "enabled": true,
          // Map of reaction ID to operation
          // When someone reacts with reaction ID "38" to bot's message, recall the message
          // "mute_proactive" suppresses proactive conversation for the group (default 10 min)
          "reactionOperations": {
            "38": "recall",
            "265": "mute_proactive"
          },
          // Duration in minutes for mute_proactive operation (default: 10)
          "muteProactiveDurationMinutes": 10
        }
      },
      // Nudge Plugin - automatically replies with bot status when bot is nudged (戳一戳)
      {
        "name": "nudge",
        "enabled": true
      },
      // Live2D Avatar Plugin — drives a VTubeStudio-connected Live2D avatar based on bot state and LLM emotion tags
      // Requires the top-level "avatar" config block to be set with enabled=true
      // {
      //   "name": "live2d-avatar",
      //   "enabled": false
      // },
      // Todo Plugin - manages project ToDo items via /todo command
      {
        "name": "todo",
        "enabled": true
      },
      // Cloudflare Worker Proxy Plugin - proxy Doubao/Volcengine API requests through Cloudflare Worker
      // Deploy worker.js in src/plugins/plugins/CloudflareWorkerPlugin/ to Cloudflare Workers first
      // {
      //   "name": "cloudflare-worker-proxy",
      //   "enabled": true,
      //   "config": {
      //     "workerUrl": "https://volcengine-proxy.your-name.workers.dev",
      //     "proxySecret": "your-secret-here",
      //     "targetProvider": "doubao"
      //   }
      // },
      // Rule Plugin - executes commands on schedule based on configured rules
      {
        "name": "rule",
        "enabled": true,
        "config": {
          // Timezone for cron jobs (default: "Asia/Tokyo")
          // Must be a valid IANA timezone identifier (e.g., "Asia/Tokyo", "Asia/Shanghai", "UTC")
          "timezone": "Asia/Tokyo",
          // List of rules to execute
          "rules": [
            {
              // Group ID where the command will be executed
              "groupId": "123456789",
              // Cron schedule expression (e.g., "0 20 * * *" for daily at 20:00)
              // Format: minute hour day month day-of-week
              "schedule": "0 20 * * *",
              // Command name to execute
              "command": "cmd",
              // Command arguments
              "args": [
                "enable",
                "t2i"
              ]
            },
            {
              "groupId": "123456789",
              "schedule": "0 22 * * *",
              "command": "cmd",
              "args": [
                "disable",
                "t2i"
              ]
            },
            // Example: dynamic whitelist - add group at 19:00 (limited: reply+proactive), remove at 22:00
            // { "groupId": "111", "schedule": "0 19 * * *", "action": "whitelist.add", "capabilities": ["reply", "proactive"] },
            // { "groupId": "111", "schedule": "0 22 * * *", "action": "whitelist.remove" },
            // Example: enable multiple commands at once
            {
              "groupId": "123456789",
              "schedule": "0 8 * * *",
              "command": "cmd",
              "args": [
                "enable",
                "t2i",
                "tts",
                "help"
              ]
            }
          ]
        }
      },
      // Log Archive Plugin - periodically compresses old log directories into tar.gz archives
      // {
      //   "name": "logArchive",
      //   "enabled": true,
      //   "config": {
      //     "intervalDays": 15,
      //     "cron": "0 3 * * *",
      //     "timezone": "Asia/Tokyo",
      //     "deleteAfterArchive": true
      //   }
      // },
      // NightlyOpsReportPlugin: scans ops/reports/ and pushes TL;DR summaries to bot owner.
      // Prerequisite: ops/nightly/ infrastructure must be set up and running (see ops/nightly/README.md).
      // {
      //   "name": "nightlyOpsReport",
      //   "enabled": false,
      //   "config": {
      //     "cron": "*/10 * * * *",
      //     "timezone": "Asia/Tokyo",
      //     "protocol": "milky"
      //   }
      // },
      // Text2Img SFW Filter Plugin - forces specific users to use SFW template for text2img commands
      {
        "name": "text2imgSfwFilter",
        "enabled": true,
        "config": {
          // Group-based user IDs that should be forced to use SFW template for text2img commands
          // Key is groupId (as string), value is array of user IDs (as numbers)
          "groupSfwUsers": {
            // Example: configure SFW users for specific groups
            // "123456789": [1001, 1002, 1003],
            // "987654321": [2001, 2002]
          }
        }
      },
      // Proactive Conversation Plugin - Ollama analysis, thread, proactive reply (Phase 1)
      {
        "name": "proactiveConversation",
        "enabled": true,
        "config": {
          "analysisProvider": "ollama", // optional: LLM for analysis/reply (default "ollama")
          "cooldownDefaultMinutes": 30, // default cooldown duration for /proactive cooldown (minutes)
          "groups": [
            {
              "groupId": "9999",
              "preferenceKey": "preference.blender"
            },
            {
              "groupId": "1",
              "preferenceKey": "preference.blender"
            }
            // Casual chat: bot actively responds to user summons (在吗/出来/聊聊 etc.)
            // { "groupId": "1", "preferenceKey": "preference.casual" },
            // Multiple preferences per group: add more entries with same groupId
            // { "groupId": "1", "preferenceKey": "preference.mihoyo" },
            // { "groupId": "1", "preferenceKey": "preference.tech" }
          ]
        }
      },
      // Memory Plugin - debounced extract from recent messages, merge with existing, inject into replies
      // Memory uses hierarchical scopes: [core_scope] or [core_scope:subtag]
      // - User scopes: identity, preference, opinion, relationship, behavior, instruction
      // - Group scopes: topic, rule, event, context
      // Subtags allow finer categorization, e.g. preference:food, identity:work
      {
        "name": "memory",
        "enabled": false,
        "config": {
          "groups": [
            "123456789"
          ],
          "debounceMs": 120000,
          "extractProvider": "deepseek",
          // Periodic memory backup (copies data/memory/ → data/backup/memory/YYYY-MM-DD/)
          "backupIntervalMs": 604800000, // 7 days (default). Set to 0 to disable.
          // "backupDir": "data/backup/memory", // Override backup directory (default)
          // Context-aware memory filtering - only inject relevant memory into AI prompts
          "filter": {
            "enabled": true, // Enable semantic filtering (default: true)
            "maxLength": 2000, // Max total chars for filtered memory (default: 2000)
            // Scopes always included regardless of relevance (supports core_scope or core_scope:subtag)
            "alwaysIncludeScopes": [
              "instruction",
              "rule"
            ],
            "minRelevanceScore": 0.1 // Minimum relevance score 0-1 (default: 0.1)
          }
        }
      },
      // Memory Trigger Plugin - on trigger phrase (e.g. bot name), merge user input into user memory (async)
      {
        "name": "memoryTrigger",
        "enabled": false,
        "config": {
          "groups": [
            "123456789"
          ],
          "triggerName": "cygnus",
          "triggerKeywords": [],
          "coldStartOnTrigger": true,
          "coldStartMaxMessages": 0,
          "coldStartBatchSize": 40
        }
      },
      // AutoAccept Plugin - automatically accepts friend requests and group invitations
      {
        "name": "autoAccept",
        "enabled": false,
        "config": {
          // Auto-accept incoming friend requests
          "acceptFriendRequests": true,
          // Auto-accept group join requests (others applying to join groups where bot is admin)
          "acceptGroupJoinRequests": false,
          // Auto-accept group invitations (bot being invited to join a group)
          "acceptGroupInvitations": true
        }
      },
      // GroupNotice Plugin - notifies group member changes (join/leave)
      // Only sends notifications in configured groups
      {
        "name": "groupNotice",
        "enabled": false,
        "config": {
          // Group IDs to enable member change notifications
          "groupIds": [
            "123456789"
          ],
          // Custom join message template (placeholders: {userId}, {groupId})
          "joinMessage": "欢迎新成员 {userId} 加入群聊！",
          // Custom leave message template (placeholders: {userId}, {groupId})
          "leaveMessage": "成员 {userId} 已离开群聊。"
        }
      },
      // Gacha Plugin - one-click NAI prompt generation (DeepSeek) then proxy to /nai
      {
        "name": "gacha",
        "enabled": true
      },
      // wechatIngest plugin: receives WeChat messages via WeChatPadPro webhook and stores them into RAG.
      // Also registers the /wechat command for reading WeChat data from QQ.
      {
        "name": "wechatIngest",
        "enabled": false, // set to true after filling in padpro credentials
        "config": {
          // HTTP webhook server — WeChatPadPro should push to http://<this-host>:<listenPort><listenPath>
          "listenPort": 9920,
          "listenPath": "/wechat/callback",
          // WeChatPadPro connection — required for /wechat command and SNS polling
          "padpro": {
            "apiBase": "http://192.168.50.97:8059", // WeChatPadPro API base URL
            "adminKey": "yourAdminKey", // Admin key (管理接口)
            "authKey": "your-auth-key-uuid", // Auth key (设备/业务接口, 30天有效期)
            "wxid": "wxid_xxxxxxxxxxxxxxx" // 已登录微信账号的 wxid
          },
          // RAG ingestion settings
          "rag": {
            "articleCollection": "wechat_articles", // 公众号文章全文存入的 Qdrant collection
            "chunksCollection": "wechat_articles_chunks", // 文章分块存入的 Qdrant collection（用于 RAG 检索）
            "momentsCollection": "wechat_moments", // 朋友圈存入的 Qdrant collection
            "bufferIdleMinutes": 5, // 空闲多少分钟后批量 upsert
            "bufferMaxMessages": 10 // 最多缓冲多少条后触发 upsert
          },
          // 公众号黑名单 — 在此列表中的公众号推送文章将被跳过不收录
          // 支持两种格式:
          //   1. 内联数组: ["公众号名称A", "公众号名称B"]
          //   2. 文本文件路径: "./data/ignored-oa-accounts.txt" (每行一个名称, # 开头为注释)
          "ignoredOAAccounts": "./data/ignored-oa-accounts.txt",
          // Real-time QQ notification when WeChat messages match a keyword/pattern
          // Disabled by default; enable and add rules as needed
          "realtime": {
            "enabled": false,
            "rules": [
              // Example: notify QQ group when WeChat message contains "紧急"
              // {
              //   "pattern": "紧急|urgent",           // regex pattern (case-insensitive)
              //   "qqGroupId": "123456789",            // target QQ group ID
              //   "template": "微信紧急消息: {text}"   // {text} is replaced with the matched message
              // }
            ]
          },
          // Daily digest — summarise WeChat RAG data and push to a QQ group via AgendaService
          // Disabled by default
          "digest": {
            "enabled": false,
            "cron": "0 22 * * *", // cron expression — default: every day at 22:00
            "targetQQGroup": "" // QQ group ID to send the digest to
          },
          // Article analysis — nightly LLM analysis of WeChat articles
          // Uses the configured LLM provider to extract facts, news, opinions from articles
          // Triggered by agenda cron item calling wechat_analyze_articles tool
          "analysis": {
            "provider": "ollama", // LLM provider name (must be configured in ai.providers)
            "maxArticles": 100, // max articles per analysis run
            "concurrency": 1 // parallel analysis tasks
            // "promptPath": "prompts/analysis/wechat_article.txt" // custom prompt template
          },
          // SNS (Moments) polling — periodically fetch 朋友圈 and store into RAG
          // Disabled by default; minimum interval 30 minutes to avoid account risk
          "sns": {
            "enabled": false,
            "pollIntervalMinutes": 30
          }
        }
      },
      // Zhihu Feed Plugin - polls Zhihu feed (关注动态), stores to SQLite, generates digests
      {
        "name": "zhihuFeed",
        "enabled": false,
        "config": {
          // Cookie from browser (must contain z_c0). Login to zhihu.com → F12 → Network → copy Cookie header
          "cookie": "",
          // Feed polling schedule (cron expression)
          "pollIntervalCron": "*/30 * * * *",
          // Digest generation + push schedule
          "digestCron": "0 9,21 * * *",
          // QQ group IDs to push digest to
          "digestGroupIds": [],
          // Minimum interval between requests (ms)
          "requestIntervalMs": 2000,
          // Max pages per poll (20 items per page)
          "maxPagesPerPoll": 5,
          // Hours of feed to include in digest
          "digestHoursBack": 12,
          // LLM provider for digest generation
          "digestProvider": "deepseek",
          // Number of top items to fetch full content for
          "topItemsToEnrich": 3,
          // Feed verb types to track
          "verbFilter": [
            "ANSWER_CREATE",
            "ARTICLE_CREATE",
            "ANSWER_VOTE_UP",
            "MEMBER_VOTEUP_ARTICLE",
            "ZVIDEO_CREATE"
          ]
        }
      },
      // GroupReport Plugin - generates group chat reports
      {
        "name": "groupReport",
        "enabled": true
      },
      // PoseLifecyclePlugin — drives avatar thinking/neutral pose lifecycle for non-IM sources
      // (avatar-cmd, bilibili-danmaku, idle-trigger, bootstrap). Requires AvatarService active.
      {
        "name": "pose-lifecycle",
        "enabled": true
      },
      // SessionStrategyPlugin — selects history adapter (conversation-history vs live2d-session) per message source
      {
        "name": "session-strategy",
        "enabled": true
      }
    ]
  },
  // Database configuration (required)
  // Choose one database type: "sqlite" or "mongodb"
  "database": {
    // SQLite configuration (simple, file-based database)
    "type": "sqlite",
    "sqlite": {
      // Path to SQLite database file (relative to project root or absolute path)
      "path": "data/bot.db"
    }
    // MongoDB configuration (alternative, for production use)
    // "type": "mongodb",
    // "mongodb": {
    //   "connectionString": "mongodb://localhost:27017",
    //   "database": "qqbot",
    //   "options": {
    //     "authSource": "admin",
    //     "user": "your_username",
    //     "password": "your_password"
    //   }
    // }
  },
  // AI configuration (optional)
  // If not configured, AI capabilities will not be available
  "ai": {
    // Enable unified reply skill-loop (single LLM call with multi-round tool execution)
    "useSkills": true,
    // Default providers by capability (optional)
    "defaultProviders": {
      "llm": "deepseek", // Default LLM provider
      "text2img": "local-text2img" // t2i command defaults to local-text2img
    },
    // LLM fallback configuration (optional)
    // Controls provider fallback order and tool-use capable providers
    // Providers that support tool/function calling
    // Tool instructions are only injected when the provider is in this list
    "toolUseProviders": [
      "doubao",
      "deepseek",
      "gemini",
      "openai",
      "anthropic"
    ],
    "llmFallback": {
      // Ordered list of providers for fallback (by cost, cheapest first)
      // Used when primary provider fails or is unhealthy
      "fallbackOrder": [
        "doubao",
        "deepseek",
        "gemini",
        "openai",
        "anthropic"
      ]
    },
    // Chat-pipeline reasoning effort (optional). Applies to the main QQ
    // conversation pipeline (NOT the avatar/Live2D path — that has its own
    // knob under `avatar.llmReasoningEffort`).
    //
    // Both default to "medium" to preserve historical behavior. The split
    // is exposed so you can tune them independently for workloads that are
    // predominantly casual chat (lower `reasoningEffort`) while keeping
    // good tool-use quality (keep `toolReasoningEffort`).
    //
    // Values: "none" | "minimal" | "low" | "medium" | "high". Only providers
    // that speak the reasoning_effort dialect (Groq qwen3-*, OpenAI o-series,
    // Anthropic extended-thinking) act on this; others ignore it.
    // "chat": {
    //   "reasoningEffort": "medium",
    //   "toolReasoningEffort": "medium"
    // },
    // Task-specific provider overrides (optional)
    // Override provider for specific internal LLM tasks
    // Falls back to defaultProviders.llm if not specified
    "taskProviders": {
      // Provider for memory extraction (MemoryPlugin)
      // "memoryExtract": "deepseek",
      // Provider for thread summarization (context compression)
      // "summarize": "deepseek",
      // Provider for lightweight/fast LLM calls (prefix-invitation, analysis)
      // "lite": "deepseek",
      // "liteModel": "deepseek-chat",
      // Provider for convert-to-card LLM calls
      // "convert": "deepseek",
      // "convertModel": "deepseek-chat",
      // Provider for article analysis (no fallback, retry-only — cost-sensitive batch task)
      "articleAnalysis": "doubao"
      // "articleAnalysisModel": "",
      // Provider for todo optimization (TodoPlugin — optimizes task description before inserting)
      // "todoOptimize": "deepseek",
      // "todoOptimizeModel": "",
      // Provider(s) for sub-agent execution (research, analysis, etc.)
      // String = fixed provider. Array = random selection per call.
      // "subagent": "deepseek",
      // "subagent": ["deepseek", "gemini"],
      // "subagentModel": ""
    },
    // AI providers configuration
    "providers": {
      // Ollama provider example
      "ollama": {
        "type": "ollama",
        "baseUrl": "http://localhost:11434",
        "model": "llama2",
        "temperature": 0.7
      },
      // OpenAI provider example
      // "openai": {
      //   "type": "openai",
      //   "apiKey": "sk-...",
      //   "model": "gpt-3.5-turbo",
      //   "baseURL": "https://api.openai.com/v1",
      //   "temperature": 0.7,
      //   "maxTokens": 2000,
      //   // Optional: enable gpt-image-2 text2img (/v1/images/generations) +
      //   // img2img (/v1/images/edits). Powers the /gpt2 command. When enabled,
      //   // OpenAIProvider also registers `text2img` + `img2img` capabilities.
      //   "image": {
      //     "enabled": true,
      //     "model": "gpt-image-2",
      //     "size": "auto",            // "1024x1024" | "1536x1024" | "1024x1536" | "auto"
      //     "quality": "auto",         // "low" | "medium" | "high" | "auto"
      //     "background": "auto",      // "transparent" | "opaque" | "auto"
      //     "outputFormat": "png",     // "png" | "jpeg" | "webp"
      //     "moderation": "auto",      // "low" | "auto"
      //     "inputFidelity": "low"     // "high" | "low" — edits-only
      //   }
      // },
      // Local Text2Image provider example (connects to local Python server)
      // "local-text2img": {
      //   "type": "local-text2img",
      //   "baseUrl": "http://localhost:8000",
      //   "endpoint": "/generate",
      //   "timeout": 300000,
      //   "censorEnabled": true,
      //   // Default values (used when options are not provided)
      //   "defaultSteps": 25,
      //   "defaultWidth": 1024,
      //   "defaultHeight": 1024,
      //   "defaultGuidanceScale": 5,
      //   "defaultNumImages": 1,
      // },
      // NovelAI provider for image generation
      // Note: Image generation uses image.novelai.net (api.novelai.net was deprecated on 2024-04-05)
      "novelai": {
        "type": "novelai",
        "accessToken": "your_novelai_access_token_here",
        "baseURL": "https://image.novelai.net",
        "model": "nai-diffusion-4-5-full", // Options: "nai-diffusion-4-5-curated", "nai-diffusion-4-5-full", "nai-diffusion-3"
        "defaultSteps": 45,
        "defaultWidth": 832,
        "defaultHeight": 1216,
        "defaultGuidanceScale": 5.0
      }
      // Gemini provider (LLM, vision, text2img, img2img). Config by capability, same pattern as laozhang.
      // "gemini": {
      //   "type": "gemini",
      //   "apiKeyFree": "your_gemini_free_tier_key",
      //   "apiKeyPaid": "your_gemini_paid_tier_key",
      //   "llm": {
      //     "model": "gemini-2.5-flash",
      //     "paidModel": "gemini-3.1-pro-preview", // Optional: upgraded model for paid-key fallback
      //     "temperature": 0.7,
      //     "maxTokens": 2000,
      //     "enableContext": true,
      //     "contextMessageCount": 10
      //   },
      //   "vision": {
      //     "model": "gemini-2.5-flash",
      //     "paidModel": "gemini-3.1-pro-preview" // Optional: upgraded model for paid-key fallback
      //   },
      //   "videoAnalysisModel": "gemini-2.5-flash", // Optional: model used for Gemini video analysis
      //   "text2img": {
      //     "model": "gemini-2.5-flash-image",
      //     "defaultWidth": 1024,
      //     "defaultHeight": 1024
      //   }
      // },
      // Doubao provider for LLM and Vision
      // Uses Doubao API (compatible with OpenAI SDK)
      // "doubao": {
      //   "type": "doubao",
      //   "apiKey": "your_ark_api_key_here",
      //   "model": "doubao-seed-1-6-lite-251015",
      //   "baseURL": "https://ark.cn-beijing.volces.com/api/v3",
      //   "reasoningEffort": "medium", // Options: "low", "medium", "high"
      //   "temperature": 0.7,
      //   "maxTokens": 2000,
      //   "enableContext": true,
      //   "contextMessageCount": 10
      // },
      // Laozhang AI provider (LLM, vision, text2img/img2img). Config by capability.
      // "laozhang": {
      //   "type": "laozhang",
      //   "apiKey": "your_laozhang_api_key_here",
      //   "baseURL": "https://api.laozhang.ai",
      //   "llm": {
      //     "model": "gemini-2.0-flash",
      //     "temperature": 0.7,
      //     "maxTokens": 2000,
      //     "enableContext": true,
      //     "contextMessageCount": 10
      //   },
      //   "vision": { "model": "gemini-2.0-flash" },
      //   "text2img": {
      //     "model": "gemini-3-pro-image-preview",
      //     "defaultAspectRatio": "16:9",
      //     "defaultImageSize": "2K"
      //   }
      // },
      // RunPod Serverless provider (T2I + I2V) - configure under ai.providers.runpod only
      // "runpod": {
      //   "type": "runpod",
      //   "endpointId": "YOUR_ENDPOINT_ID",
      //   "apiKey": "YOUR_API_KEY",
      //   "t2iEndpointId": "YOUR_T2I_ENDPOINT_ID",
      //   "timeoutMs": 600000,
      //   "pollIntervalMs": 5000
      // },
      // Google Cloud Run ComfyUI provider (T2I only) - sync POST workflow API
      // "google-cloud-run": {
      //   "type": "google-cloud-run",
      //   "baseUrl": "url of your google cloud run service",
      //   "apiKey": "",
      //   "timeoutMs": 300000
      // },
      // Groq provider (ultra-fast inference via LPU, OpenAI-compatible API)
      // "groq": {
      //   "type": "groq",
      //   "apiKey": "your_groq_api_key_here",
      //   "model": "qwen/qwen3-32b",
      //   "temperature": 0.7,
      //   "maxTokens": 2000
      // },
      // MiniMax provider (LLM + Vision). OpenAI-compatible API at https://api.minimax.io/v1
      // Supports MiniMax-M2.7, MiniMax-M2.5, MiniMax-M2.1, MiniMax-M2 and highspeed variants.
      // Vision is supported via image_url content parts (MiniMax-Text-01 model or reasoning models).
      // "minimax": {
      //   "type": "minimax",
      //   "apiKey": "your_minimax_api_key_here",
      //   "model": "MiniMax-M2.7",
      //   "temperature": 1.0,
      //   "maxTokens": 2000,
      //   "enableContext": true,
      //   "contextMessageCount": 10,
      //   "reasoningSplit": true
      // },
      // SiliconFlow provider (OpenAI-compatible proxy). Base URL: https://api.siliconflow.com/v1
      // "siliconflow": {
      //   "type": "siliconflow",
      //   "apiKey": "your_siliconflow_api_key_here",
      //   "model": "Qwen/Qwen2.5-7B-Instruct",
      //   "baseURL": "https://api.siliconflow.com/v1",
      //   "temperature": 0.7,
      //   "maxTokens": 2000,
      //   "enableContext": true,
      //   "contextMessageCount": 10
      // }
    }
  },
  // Context memory configuration (optional)
  // Controls how conversation history is stored and used
  "contextMemory": {
    // Maximum number of messages to store in memory buffer (default: 30)
    "maxBufferSize": 30,
    // Whether to use summary memory for long conversations (default: false)
    // Requires AI manager to be configured
    "useSummary": false,
    // Threshold for triggering summary when buffer exceeds this count (default: 20)
    "summaryThreshold": 20,
    // Maximum number of history messages to include in AI prompt (default: 10)
    // This limits the prompt length to prevent excessive token usage
    "maxHistoryMessages": 10
  },
  // Prompt templates configuration (required)
  // Directory path for prompt templates (relative to project root or absolute path)
  "prompts": {
    "directory": "prompts"
  },
  // TTS configuration (optional).
  //
  // Implementation lives in the bot package: `packages/bot/src/services/tts/`
  // (`TTSManager`, `FishAudioProvider`, `SovitsProvider`). Bootstrap registers
  // each provider with `HealthCheckManager` via `TtsProviderHealthAdapter` so
  // `/tts` can fall back when a backend is unhealthy.
  //
  // Multi-provider schema. Each entry in `providers[]` has a `type`
  // discriminator (`fish-audio` | `sovits`) that picks the implementation.
  // `defaultProvider` matches one of the `name` fields and is used when
  // callers omit `--provider`. Registered providers are shared between
  // `/tts` (QQ voice message path) and the avatar SpeechService (renderer
  // playback path) — synthesize once, consume twice is not wired; the two
  // pipelines are independent.
  //
  // Legacy single-provider shape (`"tts": { "apiKey": "...", "model": "s1" }`)
  // is still accepted — bootstrap synthesizes an equivalent single-entry
  // fish-audio providers array. No migration required for existing configs.
  "tts": {
    "defaultProvider": "fish-audio",
    "providers": [
      {
        "type": "fish-audio",
        "name": "fish-audio",
        "apiKey": "your_fish_audio_api_key_here",
        "model": "s1",
        "format": "mp3",
        // Optional: name → reference_id map. `/tts --voice=<name>` picks
        // entries from this map. If empty, only `defaultVoice` is usable.
        "voiceMap": {
          "蔡徐坤": "e4642e5edccd4d9ab61a69e82d4f8a14",
          "丁真": "54a5170264694bfc8e9ad98df7bd89c3",
          "赛马娘": "561fcedfdf0e4e1399d1bc4930d50c0e",
          "孙笑川": "e80ea225770f42f79d50aa98be3cedfc",
          "丰川祥子": "f544cd9b956740c4a1bdee2e93a23d20",
          "雷军": "aebaa2305aa2452fbdc8f41eec852a79",
          "特朗普": "5196af35f6ff4a0dbf541793fc9f2157",
          "日语": "fbea303b64374bffb8843569404b095e",
          "高松灯": "b4f70fdef5f943c2bf43db00e80ad680",
          "卢本伟": "e5c5bebffac04f858878e21f8598deb1",
          "永雏塔菲": "55b28b196e1c4fff9a55cd32a46eff25",
          "派蒙": "eacc56f8ab48443fa84421c547d3b60e",
          "嘉然": "e11b0496fc9f4cb180db1dd238f67833",
          "东雪莲": "eaa47f801d914afe93ea453cc42729f3"
        },
        "defaultVoice": "高松灯"
      }
      // Example: GPT-SoVITS `api_v2.py` (POST /tts). Field names follow that API;
      // `ref_audio_path` is a path on the host that runs the API. Docs:
      // docs/local/GPT-SoVITS-API-v2-integration.md
      //
      // `bodyTemplate` carries ONLY stable synthesis params. Streaming fields
      // (`streaming_mode`, `media_type`) are owned by the provider and forced
      // per-call — do NOT put them here, they'll be silently overwritten:
      //   - /tts command (QQ voice record) → forces streaming_mode=false, media_type=wav
      //   - renderer / Live2D (SpeechService)  → forces streaming_mode=true, media_type=raw
      // `pcmSampleRate` is the sample rate of the raw-PCM stream used by the
      // renderer path; wav (the /tts command path) carries its own rate in-band.
      // ,{
      //   "type": "sovits",
      //   "name": "sovits-lan",
      //   "endpoint": "http://192.168.1.50:9880/tts",
      //   "pcmSampleRate": 32000,
      //   "bodyTemplate": {
      //     "text": "{text}",
      //     "text_lang": "zh",
      //     "ref_audio_path": "D:/path/to/reference.wav",
      //     "prompt_text": "参考音频对应文本",
      //     "prompt_lang": "zh"
      //   }
      // }
    ]
  },
  // MCP configuration (optional)
  // MCP (Model Context Protocol) configuration for RAG search functionality
  "mcp": {
    "enabled": true,
    "searxng": {
      "url": "http://localhost:8080"
      // Optional: HTTP Basic Auth credentials
      // "authUsername": "user",
      // "authPassword": "pass",
      // Optional: Custom User-Agent header
      // "userAgent": "qqbot/1.0",
      // Optional: Proxy configuration
      // "proxy": {
      //   "http": "http://proxy:8080",
      //   "https": "http://proxy:8080"
      // }
    },
    "server": {
      "enabled": false, // false = direct API mode, true = MCP server mode
      "runtime": "bunx", // "bunx" | "npx" | "npm"
      "package": "mcp-searxng"
    },
    "search": {
      "enabled": true,
      "mode": "direct", // "direct" (SearXNG API) or "mcp" (MCP server)
      "autoTrigger": true, // Automatically trigger search when needed
      "triggerStrategy": "llm", // "llm" (use LLM to judge) | "keywords" | "none"
      "maxResults": 5, // Maximum number of search results
      "language": "all", // Default language for search results
      "engines": "bing,duckduckgo,google,baidu", // Default search engines (SearXNG only uses wikipedia by default)
      // Optional: full-page fetch after filter-refine (fetch HTML for top 2-3 results, extract article/video description)
      "fetch": {
        "fetchFullPage": false, // Set true to fetch full page content for top results
        "maxUrlsToFetch": 3, // Max URLs to fetch (article or video description)
        "maxCharsPerPage": 6000, // Max characters per article page (proxy for tokens)
        "maxCharsPerVideoDescription": 2000, // Max characters per video description
        "fetchTimeoutMs": 10000 // Timeout in ms for each fetch
        // "skipFetchPatterns": ["\\.pdf$", "file://"], // URL patterns to skip fetch (regex)
        // "videoDescriptionSelectors": { "www.bilibili.com": ".desc, .video-desc" } // Host -> CSS selector for video description
      }
    }
  },
  // RAG configuration (optional) - vector retrieval for conversation history
  // When enabled: messages are embedded via Ollama and stored in Qdrant; reply stage queries by vector for context.
  // Prerequisites: Ollama running with an embedding model (e.g. ollama pull qwen3-embedding:4b), Qdrant running (e.g. docker run -p 6333:6333 qdrant/qdrant).
  "rag": {
    "enabled": false,
    "ollama": {
      "url": "http://localhost:11434",
      "model": "qwen3-embedding:4b",
      "timeout": 30000
    },
    "qdrant": {
      "url": "http://localhost:6333",
      "apiKey": null,
      "timeout": 30000
    },
    "queryInstructionPrefix": "Instruct: Retrieve relevant conversation history\nQuery: ",
    "defaultVectorSize": 2560,
    "defaultDistance": "Cosine"
  },
  // Claude Code Service configuration (optional)
  // Enables integration with Claude Code CLI for AI-powered task execution
  // The service exposes an HTTP API that Claude Code can call to:
  // - Notify the bot of task status
  // - Send messages via the bot
  // - Get bot status information
  "claudeCodeService": {
    "enabled": false,
    "port": 9090,
    "host": "127.0.0.1",
    // Claude Code CLI path (default: 'claude')
    "claudeCliPath": "claude",
    // Working directory for Claude Code tasks
    "workingDirectory": "./",
    // Max concurrent tasks (default: 1)
    "maxConcurrentTasks": 1,
    // Project registry for multi-project support (optional)
    // When configured, enables cross-directory project operations via @alias syntax
    "projectRegistry": {
      // Security whitelist: only allow projects under these directories
      "allowedBasePaths": [
        "/home/user/projects"
      ],
      // Default project alias (used when no @alias specified)
      "defaultProject": "qqbot",
      // Pre-registered projects
      "projects": [
        {
          "alias": "qqbot",
          "path": "./",
          "type": "bun",
          "description": "QQBot - QQ群聊机器人"
        }
        // {
        //   "alias": "myapi",
        //   "path": "/home/user/projects/my-api",
        //   "type": "bun",
        //   "description": "My REST API"
        // }
      ]
    }
  },
  // Video Knowledge Backend integration (optional)
  // Provides video analysis capabilities for bilibili videos.
  // The backend analyzes video content (subtitles, danmaku) and generates summaries/highlights.
  "videoKnowledge": {
    "enabled": false,
    // Base URL of the video-knowledge-backend service
    "baseURL": "http://localhost:8080",
    // Local directory where analysis results are stored (only for local deployment)
    // Path pattern: {dataDir}/kb/{creator_name}/{date}-{sanitized_title}.json
    "dataDir": "../video-knowledge-backend/data",
    // Polling interval in milliseconds when waiting for analysis to complete (default: 5000)
    "pollIntervalMs": 5000,
    // Polling timeout in milliseconds (default: 300000 = 5 minutes)
    "pollTimeoutMs": 300000
  },
  // Project registry — shared across ClaudeCode and Cluster workers.
  // Defines allowed project directories and pre-registered projects.
  "projectRegistry": {
    // Security whitelist: only allow projects under these directories
    "allowedBasePaths": [
      "/home/user/projects"
    ],
    // Default project alias (used when no @alias specified)
    "defaultProject": "default",
    // Pre-registered projects
    "projects": [
      // {
      //   "alias": "my-project",
      //   "path": "/home/user/projects/my-project",
      //   "type": "bun",
      //   "description": "My Project"
      // }
    ]
  },
  // Agent Cluster — local multi-agent task execution.
  // Spawns coding agent workers (Claude Code / Codex / Gemini / MiniMax /
  // DeepSeek) to process tasks autonomously. Disabled by default. The full
  // template (with all providers + tokens) lives in config.d/cluster.jsonc
  // which is gitignored — keep API keys there, not here.
  //
  // Supported worker template `type` values:
  //   - "claude-cli"   Claude Code CLI (also Anthropic-compat endpoints
  //                    via ANTHROPIC_BASE_URL env override)
  //   - "minimax-cli"  MiniMax M2 CN via anthropic-compat façade
  //   - "deepseek-cli" DeepSeek via anthropic-compat façade
  //                    (auth via ANTHROPIC_AUTH_TOKEN, not _API_KEY)
  //   - "codex-cli"    OpenAI Codex CLI (`codex exec`)
  //   - "gemini-cli"   Google Gemini CLI (`gemini -p`)
  //
  // Each template inherits process.env and merges its own `env` on top,
  // so you can ship per-template API keys / model overrides.
  "cluster": {
    "enabled": false,
    // Identifier for this cluster instance. Written into
    // tickets/<id>/results/job.json so cross-LAN WebUI viewers can tell
    // which machine produced a given result (cluster-tickets is a shared
    // git-synced repo; each LAN machine runs its own independent cluster).
    // Optional — defaults to the machine's hostname.
    // "clusterId": "mac-mini",
    "schedulingInterval": "30s",
    "maxConcurrentWorkers": 4,
    "hub": {
      "host": "127.0.0.1",
      "port": 3200,
      "lockTTL": "10m",
      "eventLogMaxSize": 2000
    },
    "workerTemplates": {
      "claude-sonnet": {
        "type": "claude-cli",
        // Phase 3 multi-agent: omit `role` (defaults to "executor") for
        // single-task workers. Tag a template with `"role": "planner"` to
        // make it eligible for planner-mode ticket dispatch (see
        // `defaultPlannerTemplate` and ticket `usePlanner: true` below).
        "command": "claude",
        "args": [
          "--print",
          "--dangerously-skip-permissions",
          "--output-format",
          "text"
        ],
        "maxConcurrent": 2,
        "timeout": "20m",
        "capabilities": [
          "code"
        ],
        "costTier": "medium"
      }
      // Example planner template (uncomment + customize):
      // "claude-opus-planner": {
      //   "type": "claude-cli",
      //   "role": "planner",
      //   "command": "claude",
      //   "args": ["--print", "--dangerously-skip-permissions", "--model", "opus"],
      //   "maxConcurrent": 1,
      //   "timeout": "30m",
      //   "capabilities": ["plan"],
      //   "costTier": "high"
      // }
      //
      // Heavy executor templates for complex tasks (planner dispatches
      // to these only when standard executors are insufficient):
      // "claude-opus":  claude-cli + opus model (top-tier reasoning)
      // "codex-full":   codex-cli + gpt-5.4-codex (algorithm/math)
      // "gemini-pro":   gemini-cli + gemini-3.1-pro (huge context)
      //
      // See config.d/cluster.jsonc for full template examples including
      // codex-cli / gemini-cli / minimax-m2 / deepseek-coder / heavy executors.
    },
    // Phase 3 multi-agent: when a ticket has `usePlanner: true` but doesn't
    // pin its own template, the scheduler picks this one. Must reference a
    // template whose `role === 'planner'`. Optional — falls back to
    // scanning workerTemplates for any planner-role entry.
    // "defaultPlannerTemplate": "claude-opus-planner",
    "projects": {
      "qqbot": {
        "maxWorkers": 2,
        "taskSources": [
          {
            "type": "queue"
          }
        ],
        "workerPreference": "claude-sonnet"
      }
    }
  },
  // Avatar system — Live2D / VTubeStudio integration (optional).
  // Set enabled=true and configure the sub-sections to activate.
  // "avatar": {
  //   "enabled": false,
  //
  //   // VTubeStudio WebSocket API connection. Set enabled=false to skip
  //   // the driver entirely (use with the self-hosted Cubism renderer that
  //   // consumes preview WS directly).
  //   "vts": {
  //     "enabled": true,
  //     "host": "localhost",
  //     "port": 8001,
  //     "pluginName": "qqbot-avatar",
  //     "pluginDeveloper": "qqbot",
  //     "tokenFilePath": "data/avatar/.vts-token",
  //     "throttleFps": 30
  //   },
  //
  //   // Animation compiler settings
  //   "compiler": {
  //     "fps": 60,
  //     "outputFps": 60,
  //     "defaultEasing": "easeInOutCubic",
  //     "attackRatio": 0.2,
  //     "releaseRatio": 0.3,
  //     // crossfadeMs: duration in ms for the fade-out of an old animation when
  //     // a new animation starts on overlapping channels. Also controls the
  //     // fade-in of the new animation on those channels. Default: 250.
  //     // "crossfadeMs": 250,
  //     // baselineHalfLifeMs: exponential decay half-life in ms for the
  //     // endPose baseline written by envelope-kind animations on release.
  //     // Shorter = envelope endPose hands off back to the idle-clip posture
  //     // sooner, reducing cross-namespace contention on shared bones.
  //     // Default: 3000 ms (≈ one conversational turn).
  //     // "baselineHalfLifeMs": 3000
  //     // clipEnvelope: attack/release ramp for clip-kind actions (ms).
  //     // attackMs: linear fade-in duration (default 200, clamped to duration*0.5).
  //     // releaseMs: linear fade-out duration (default 300, clamped to duration*0.5).
  //     // "clipEnvelope": {
  //     //   "attackMs": 200,
  //     //   "releaseMs": 300
  //     // },
  //     // jitter: randomization applied to `enqueueTagAnimation` calls
  //     // (LLM-authored tags). duration default ±0.15 (=±15%), intensity
  //     // default ±0.10 (=±10%), intensityFloor clamps post-jitter intensity
  //     // to at least 0.1. Set any field to 0 to disable that axis. NOT
  //     // applied to state-transition nodes (setActivity path).
  //     // "jitter": {
  //     //   "duration": 0.15,
  //     //   "intensity": 0.10,
  //     //   "intensityFloor": 0.1
  //     // }
  //     // idle: compiler-side idle motion config. `loopClipActionName` names
  //     // a `kind:'clip'` action to loop continuously — the loop clip is the
  //     // sole source of truth for the character's resting pose on VRM. On
  //     // gate exit (speaking / listening / thinking) the layer freezes the
  //     // clip at the current frame and resumes from that frame on re-entry,
  //     // keeping posture continuous across state transitions. Unset = legacy
  //     // gap-based one-shot clip pool (Cubism idle style).
  //     // "idle": {
  //     //   "loopClipActionName": "idle_standing"
  //     // }
  //   },
  //
  //   // Idle state machine intervals (milliseconds)
  //   "idle": {
  //     "idleIntervalMin": 3000,
  //     "idleIntervalMax": 8000
  //   },
  //
  //   // Live preview server — streams parameter frames via WebSocket
  //   "preview": {
  //     "enabled": false,
  //     "port": 8002,
  //     "host": "0.0.0.0"
  //   },
  //
  //   // Action map. Omitted = @qqbot/avatar merges `assets/core-action-map.json` (hand)
  //   // with `assets/vrm-extend-action-map.json` (generated: `bun run gen:vrm-extend` in
  //   // packages/avatar). Set "path" to a single JSON file to replace the whole default (no merge).
  //   "actionMap": {
  //     // "path": "config/my-action-map.json"
  //   },
  //
  //   // Text-to-speech settings. Requires a usable `tts` provider.
  //   "speech": {
  //     "enabled": true,
  //     "maxCharsPerUtterance": 80,
  //     "utteranceGapMs": 200
  //   },
  //
  //   // LLM for Live2D only (`/avatar`, Bilibili live → avatar, livemode). Must
  //   // match a name under `ai.providers`. Unset = `ai.defaultProviders.llm` (e.g. deepseek).
  //   "llmProvider": "doubao",
  //   // `llmStream` true = API streaming; false = one-shot `generate` (default). Override per run: `meta.llmStream`.
  //   "llmStream": false
  // },
  // Bilibili integration.
  //
  // `bilibili.live` turns on the live-room danmaku listener. When enabled:
  //   - Danmaku are written to the `bilibili_danmaku` table (async; no impact
  //     on the hot receive path) for later RAG / analytics.
  //   - The buffer aggregates/dedups over `flushIntervalMs` and forwards the
  //     batched summary to Live2DPipeline, which drives the avatar reaction.
  //   - `send.enabled=true` (default false) unlocks the BilibiliLiveClient
  //     .sendDanmaku() capability — currently only exposed programmatically;
  //     no auto-reply wiring yet.
  //
  // Cookies:
  //   - `sessdata`: SESSDATA cookie value. Used ONLY by sendDanmaku() (the
  //     REST POST path). The WS receive path runs anonymously with
  //     `platform=danmuji` because mixing SESSDATA + danmuji triggers
  //     bilibili's risk control ("third-party client claims web login").
  //     Leave empty if you don't plan to send.
  //   - `biliJct`: bili_jct (CSRF) cookie value. Required only for sending.
  //
  // "bilibili": {
  //   "live": {
  //     "enabled": false,
  //     "autoConnect": false,     // use /live2d connect on demand; default false
  //     "roomId": 12345,
  //     "sessdata": "",
  //     "biliJct": "",
  //     "pipeToLive2D": true,
  //     "streamerAliases": ["Ava", "阿娃"],
  //     "buffer": {
  //       "flushIntervalMs": 3000,
  //       "maxTextLen": 500
  //     },
  //     "send": {
  //       "enabled": false
  //     }
  //   }
  // },
  // Tickets storage (optional) — externalize ticket markdown out of the bot
  // repo so cross-project work items can live in their own git history.
  // Absolute path recommended. Relative resolves against process.cwd().
  // Omit this block to fall back to `<cwd>/tickets`.
  //
  // Expected layout under the configured directory:
  //   .templates/ticket.md   — default body skeleton rendered by WebUI
  //   <id>/ticket.md         — the ticket
  //   <id>/plan.md           — planner's decomposition (cluster only)
  //   <id>/results/          — auto-generated execution artifacts
  "tickets": {
    "dir": "/absolute/path/to/cluster-tickets"
  },
  // Mind system — phenotype ODE + modulation provider for the avatar.
  // See docs/local/mind-system-design.md. Phase 1 only implements fatigue +
  // attention and drives avatar intensity / speed multipliers. Disabled by
  // default; enable alongside "avatar" to see persona modulation kick in.
  // "mind": {
  //   "enabled": false,
  //   "personaId": "default",      // 对应 data/mind/persona/<id>/{core-dna.json,bible.md} 目录
  //   "dataDir": "./data/mind",    // SQLite 反思日志 + persona 文件根目录
  //   "tickMs": 1000,
  //
  //   // ODE time constants. Defaults match mergeMindConfig().
  //   // "ode": {
  //   //   "tauAttentionMs": 120000,        // 2 min exponential decay
  //   //   "fatigueAccrualPerMs": 5e-7,     // full fatigue over ~33 min active
  //   //   "fatigueRestDecayPerMs": 1e-6,   // full recovery over ~16 min idle
  //   //   "attentionSpikePerMessage": 0.3
  //   // },
  //
  //   // Phenotype → avatar modulation mapping. Note: Core DNA JSON
  //   // (data/mind/persona/<id>/core-dna.json) overrides these — these
  //   // keys 只在 Core DNA 缺该字段或 user-config 显式 override 时生效。
  //   // "modulation": {
  //   //   "fatigueIntensityDrop": 0.4,  // at fatigue=1.0 → 60% intensity
  //   //   "fatigueSpeedDrop": 0.3       // at fatigue=1.0 → 70% speed
  //   // },
  //
  //   // Phase 2/3.5: Prompt-patch behaviour — inject persona context into
  //   // the reply pipeline's system prompt. Requires plugin "mind-prompt"
  //   // enabled in plugins.jsonc.
  //   //
  //   // 注入块（按出现顺序）：
  //   //   <persona_identity>     ← bible.md Self-concept + Voice + Lore（injectBible 控制）
  //   //   <persona_boundaries>   ← bible.md Boundaries 段（injectBible 控制）
  //   //   <mind_state>           ← fatigue → moodSummary（fatigue*Min 控制）
  //   //   <relationship_state>   ← per-user affinity / familiarity 摘要
  //   //   <tone_state>           ← System 2 反思当前 tone 片段
  //   // "promptPatch": {
  //   //   "enabled": true,
  //   //   "fatigueMildMin": 0.3,        // below this → no mood injection
  //   //   "fatigueModerateMin": 0.55,
  //   //   "fatigueSevereMin": 0.8,
  //   //   "injectBible": true,          // false → 跳过 identity / boundaries 块（bible 仍喂 reflection）
  //   //   "bibleMaxCharsPerSection": 800 // 每段 truncate 上限（含中文按字符计）
  //   // },
  //
  //   // Phase 3: Autonomous wander — periodic low-amplitude idle motion.
  //   // Gated to neutral pose (never fires while speaking/listening/thinking).
  //   // Requires the avatar system to be active.
  //   // "wander": {
  //   //   "enabled": true,
  //   //   "intervalMinMs": 10000,
  //   //   "intervalMaxMs": 20000,
  //   //   "cooldownMs": 10000,
  //   //   "intents": {                // weighted random over intent kinds
  //   //     "glance": 0.15,
  //   //     "look_around": 0.1,
  //   //     "shift_weight": 0.08,
  //   //     "micro_step": 0.05,
  //   //     "browse": 0.02,
  //   //     "idle_clip": 0.6          // dominant: pick a clip from idleClipPool
  //   //   },
  //   //   "amplitude": {              // caps on per-step magnitudes
  //   //     "maxTurnRad": 0.524,      // ≈ 30°
  //   //     "maxStepMeters": 0.25,
  //   //     "maxStrafeMeters": 0.2
  //   //   },
  //   //   "idleClipPool": ["vrm_idle_loop"]
  //   // }
  //
  //   // Phase 3: Autonomous triggers — translate phenotype state into discrete
  //   // avatar actions. Fatigue → yawn-like refresh clip on a 5–10 min cooldown.
  //   // Valence → emotion drift (sad / smile / thinking) as a hysteresis state
  //   // machine. Requires "avatar" enabled.
  //   // "autonomousTrigger": {
  //   //   "enabled": true,
  //   //   "yawn": {
  //   //     "fatigueThreshold": 0.8,
  //   //     "cooldownMinMs": 300000,
  //   //     "cooldownMaxMs": 600000,
  //   //     "actionName": "vrm_emotion_refresh",
  //   //     "intensity": 0.6
  //   //   },
  //   //   "valenceDrift": {
  //   //     "negativeThreshold": -0.3,
  //   //     "positiveThreshold": 0.5,
  //   //     "neutralLowMin": -0.1,
  //   //     "neutralHighMax": 0.3,
  //   //     "sadEmotionName": "emotion_sad",
  //   //     "happyEmotionName": "emotion_smile",
  //   //     "neutralEmotionName": "emotion_thinking",
  //   //     "sadIntensityMin": 0.2,
  //   //     "sadIntensityMax": 0.5,
  //   //     "sadIntensityFactor": 0.6,
  //   //     "happyIntensityMin": 0.3,
  //   //     "happyIntensityMax": 0.6,
  //   //     "happyIntensityFactor": 0.5
  //   //   }
  //   // }
  // }
}