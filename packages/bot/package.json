{
  "name": "@qqbot/bot",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "build": "bun run scripts/builds/build.ts production",
    "build:dev": "bun run scripts/builds/build.ts development",
    "build:all": "bun run scripts/builds/build.ts bundleAll",
    "build:watch": "bun build src/index.ts --outdir dist --target bun --watch",
    "typecheck": "tsc -b --noEmit",
    "smoke-test": "NO_FILE_LOG=1 bun run src/cli/smoke-test.ts",
    "debug": "bun run src/cli/debug.ts LOG_LEVEL=debug --mock",
    "cluster:e2e": "NO_FILE_LOG=1 bun run src/cli/cluster-e2e.ts",
    "cluster:e2e:claude": "NO_FILE_LOG=1 bun run src/cli/cluster-e2e.ts --suite claude",
    "cluster:e2e:gemini": "NO_FILE_LOG=1 bun run src/cli/cluster-e2e.ts --suite gemini",
    "cluster:e2e:codex": "NO_FILE_LOG=1 bun run src/cli/cluster-e2e.ts --suite codex",
    "test": "bun test",
    "test:network": "NETWORK_TESTS=1 bun test"
  },
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mozilla/readability": "^0.6.0",
    "@qqbot/avatar": "workspace:*",
    "@saltify/milky-types": "^1.1.0",
    "@types/jsdom": "^28.0.0",
    "adm-zip": "^0.5.16",
    "async_hooks": "^1.0.0",
    "better-sqlite3": "^12.6.2",
    "discord.js": "^14.25.1",
    "jsdom": "^25.0.1",
    "jsonc-parser": "^3.3.1",
    "mongodb": "^7.1.0",
    "node-cron": "^3.0.3",
    "openai": "^6.27.0",
    "puppeteer-core": "^21.11.0",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.33.5",
    "tsyringe": "^4.10.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/node-cron": "^3.0.11"
  }
}
