{
  "smile": {
    "params": [
      { "channel": "mouth.smile", "targetValue": 1.0, "weight": 1.0 },
      { "channel": "brow", "targetValue": 0.3, "weight": 0.5 }
    ],
    "defaultDuration": 2000
  },
  "nod": {
    "params": [
      { "channel": "head.pitch", "targetValue": -15.0, "weight": 1.0 },
      { "channel": "body.y", "targetValue": -0.3, "weight": 0.6 }
    ],
    "defaultDuration": 800
  },
  "wave": {
    "params": [
      { "channel": "head.roll", "targetValue": 5.0, "weight": 1.0 },
      { "channel": "body.x", "targetValue": 0.15, "weight": 0.4 }
    ],
    "defaultDuration": 1500
  },
  "thinking": {
    "params": [
      { "channel": "head.yaw", "targetValue": 10.0, "weight": 0.7 },
      { "channel": "head.roll", "targetValue": -8.0, "weight": 0.5 },
      { "channel": "eye.open.left", "targetValue": 0.6, "weight": 0.8 },
      { "channel": "eye.open.right", "targetValue": 0.6, "weight": 0.8 },
      { "channel": "brow", "targetValue": -0.3, "weight": 0.6 }
    ],
    "defaultDuration": 3000
  },
  "sad": {
    "params": [
      { "channel": "mouth.smile", "targetValue": 0.0, "weight": 1.0 },
      { "channel": "brow", "targetValue": -0.5, "weight": 0.8 },
      { "channel": "head.pitch", "targetValue": -8.0, "weight": 0.6 },
      { "channel": "body.y", "targetValue": -0.15, "weight": 0.5 }
    ],
    "defaultDuration": 2500
  },
  "angry": {
    "params": [
      { "channel": "brow", "targetValue": -0.8, "weight": 1.0 },
      { "channel": "mouth.smile", "targetValue": 0.0, "weight": 0.7 },
      { "channel": "eye.open.left", "targetValue": 0.4, "weight": 0.6 },
      { "channel": "eye.open.right", "targetValue": 0.4, "weight": 0.6 }
    ],
    "defaultDuration": 1800
  },
  "surprised": {
    "params": [
      { "channel": "mouth.open", "targetValue": 0.8, "weight": 1.0 },
      { "channel": "eye.open.left", "targetValue": 1.0, "weight": 1.0 },
      { "channel": "eye.open.right", "targetValue": 1.0, "weight": 1.0 },
      { "channel": "brow", "targetValue": 0.6, "weight": 0.8 },
      { "channel": "head.roll", "targetValue": 3.0, "weight": 0.3 }
    ],
    "defaultDuration": 1200
  },
  "idle_blink": {
    "params": [
      { "channel": "eye.open.left", "targetValue": 0.0, "weight": 1.0 },
      { "channel": "eye.open.right", "targetValue": 0.0, "weight": 1.0 }
    ],
    "defaultDuration": 150
  },
  "blink": {
    "params": [
      { "channel": "eye.open.left", "targetValue": 0.0, "weight": 1.0 },
      { "channel": "eye.open.right", "targetValue": 0.0, "weight": 1.0 }
    ],
    "defaultDuration": 300
  },
  "head_sway": {
    "params": [
      { "channel": "head.yaw", "targetValue": 15.0, "weight": 1.0 },
      { "channel": "body.x", "targetValue": 0.1, "weight": 0.5 }
    ],
    "defaultDuration": 3000
  },
  "breathe": {
    "params": [
      { "channel": "body.y", "targetValue": 0.05, "weight": 1.0 }
    ],
    "defaultDuration": 4000
  },
  "lean_forward": {
    "params": [
      { "channel": "body.z", "targetValue": 0.2, "weight": 1.0 },
      { "channel": "head.pitch", "targetValue": -5.0, "weight": 0.7 }
    ],
    "defaultDuration": 1000
  },
  "lean_back": {
    "params": [
      { "channel": "body.z", "targetValue": -0.2, "weight": 1.0 },
      { "channel": "head.pitch", "targetValue": 3.0, "weight": 0.7 }
    ],
    "defaultDuration": 1000
  },
  "tilt_head": {
    "params": [
      { "channel": "head.roll", "targetValue": 15.0, "weight": 1.0 }
    ],
    "defaultDuration": 1200
  },
  "shake_head": {
    "params": [
      { "channel": "head.yaw", "targetValue": 15.0, "weight": 1.0 }
    ],
    "defaultDuration": 800
  },
  "shrug": {
    "params": [
      { "channel": "body.y", "targetValue": 0.1, "weight": 1.0 },
      { "channel": "head.roll", "targetValue": 3.0, "weight": 0.3 }
    ],
    "defaultDuration": 1200
  }
}
