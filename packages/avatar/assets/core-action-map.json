{
  "emotion_smile": {
    "category": "emotion",
    "modelSupport": "both",
    "description": "露出笑容,嘴角上扬,眼睛微眯——开心或友好的表情",
    "params": [
      { "channel": "mouth.smile", "targetValue": 1.0, "weight": 1.0 },
      { "channel": "eye.smile.left", "targetValue": 0.7, "weight": 0.9 },
      { "channel": "eye.smile.right", "targetValue": 0.7, "weight": 0.9 },
      { "channel": "brow", "targetValue": 0.3, "weight": 0.5 }
    ],
    "defaultDuration": 2000
  },
  "emotion_sad": {
    "category": "emotion",
    "modelSupport": "both",
    "description": "眉头下垂、低头,面露沮丧——失落或难过",
    "params": [
      { "channel": "mouth.smile", "targetValue": 0.0, "weight": 1.0 },
      { "channel": "brow", "targetValue": -0.5, "weight": 0.8 },
      { "channel": "head.pitch", "targetValue": -8.0, "weight": 0.6 },
      { "channel": "body.y", "targetValue": -0.15, "weight": 0.5 }
    ],
    "defaultDuration": 2500
  },
  "emotion_angry": {
    "category": "emotion",
    "modelSupport": "both",
    "description": "皱眉瞪眼、嘴角紧绷——生气或不满",
    "params": [
      { "channel": "brow", "targetValue": -0.8, "weight": 1.0 },
      { "channel": "mouth.smile", "targetValue": 0.0, "weight": 0.7 },
      { "channel": "eye.open.left", "targetValue": -0.6, "weight": 0.6 },
      { "channel": "eye.open.right", "targetValue": -0.6, "weight": 0.6 }
    ],
    "defaultDuration": 1800
  },
  "emotion_surprised": {
    "category": "emotion",
    "modelSupport": "both",
    "description": "张嘴挑眉、头轻仰——吃惊或出乎意料",
    "params": [
      { "channel": "mouth.open", "targetValue": 0.8, "weight": 1.0 },
      { "channel": "brow", "targetValue": 0.6, "weight": 0.8 },
      { "channel": "head.roll", "targetValue": 3.0, "weight": 0.3 }
    ],
    "defaultDuration": 1200
  },
  "emotion_thinking": {
    "category": "emotion",
    "modelSupport": "both",
    "description": "微微歪头眯眼,皱眉思索——表达在思考或权衡",
    "params": [
      { "channel": "head.yaw", "targetValue": 10.0, "weight": 0.7 },
      { "channel": "head.roll", "targetValue": -8.0, "weight": 0.5 },
      { "channel": "eye.open.left", "targetValue": -0.4, "weight": 0.8 },
      { "channel": "eye.open.right", "targetValue": -0.4, "weight": 0.8 },
      { "channel": "brow", "targetValue": -0.3, "weight": 0.6 }
    ],
    "defaultDuration": 3000
  },
  "micro_blink": {
    "category": "micro",
    "modelSupport": "both",
    "description": "一次明显的眨眼——俏皮的眨眼或强调(区别于自动眨眼)",
    "params": [
      { "channel": "eye.open.left", "targetValue": -1.0, "weight": 1.0 },
      { "channel": "eye.open.right", "targetValue": -1.0, "weight": 1.0 }
    ],
    "defaultDuration": 300
  },
  "micro_head_sway": {
    "category": "micro",
    "modelSupport": "both",
    "description": "头部缓慢左右摆动——放松、有节奏感的待机动作",
    "params": [
      { "channel": "head.yaw", "targetValue": 15.0, "weight": 1.0 },
      { "channel": "body.x", "targetValue": 0.1, "weight": 0.5 }
    ],
    "defaultDuration": 3000
  },
  "micro_shake_head": {
    "category": "micro",
    "modelSupport": "both",
    "description": "摇头两次——否定、拒绝或无奈",
    "params": [
      { "channel": "head.yaw", "targetValue": 22.0, "weight": 1.0, "oscillate": 2 },
      { "channel": "body.x", "targetValue": -0.08, "weight": 0.4, "oscillate": 2 }
    ],
    "defaultDuration": 1400
  },
  "micro_tilt_head": {
    "category": "micro",
    "modelSupport": "both",
    "description": "歪头——表示困惑、好奇或俏皮",
    "params": [{ "channel": "head.roll", "targetValue": 15.0, "weight": 1.0 }],
    "defaultDuration": 1200
  }
}
