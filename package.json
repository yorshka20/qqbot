{
  "name": "qqbot",
  "version": "1.0.0",
  "description": "QQ Bot with multi-protocol support (Milky, OneBot11, Satori)",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n bot,ui -c blue,green \"LOG_LEVEL=debug bun run src/index.ts\" \"cd webui && bun run dev\"",
    "build": "bun run scripts/build.ts production",
    "build:dev": "bun run scripts/build.ts development",
    "build:all": "bun run scripts/build.ts bundleAll",
    "build:watch": "bun build src/index.ts --outdir dist --target bun --watch",
    "build:admin": "cd webui && bun run build",
    "start": "bun dist/index.js",
    "debug": "bun run src/cli/debug.ts LOG_LEVEL=debug --mock",
    "type-check": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "test": "bun test"
  },
  "keywords": [
    "qqbot",
    "qq",
    "bot",
    "milky",
    "onebot",
    "satori"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "bun@1.0.0",
  "dependencies": {
    "@google/genai": "^1.44.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@mozilla/readability": "^0.6.0",
    "@saltify/milky-types": "^1.1.0",
    "@types/jsdom": "^28.0.0",
    "adm-zip": "^0.5.16",
    "async_hooks": "^1.0.0",
    "better-sqlite3": "^12.6.2",
    "jsdom": "^25.0.1",
    "jsonc-parser": "^3.3.1",
    "mongodb": "^7.1.0",
    "node-cron": "^3.0.3",
    "openai": "^6.27.0",
    "puppeteer-core": "^21.11.0",
    "reflect-metadata": "^0.2.2",
    "sharp": "^0.33.5",
    "tsyringe": "^4.10.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "@biomejs/biome": "^2.4.6",
    "@types/adm-zip": "^0.5.7",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/node-cron": "^3.0.11",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
