{
  "name": "qqbot",
  "version": "1.0.0",
  "description": "QQ Bot with multi-protocol support (Milky, OneBot11, Satori)",
  "type": "module",
  "packageManager": "bun@1.0.0",
  "workspaces": ["packages/*"],
  "scripts": {
    "start": "bash start.sh",
    "web": "bun run --filter @qqbot/webui dev",
    "dev": "concurrently -n bot,ui -c blue,green \"bun run packages/bot/src/index.ts\" \"bun run --filter @qqbot/webui dev\"",
    "build": "bun run --filter @qqbot/bot build",
    "build:dev": "bun run --filter @qqbot/bot build:dev",
    "build:all": "bun run --filter @qqbot/bot build:all",
    "build:watch": "bun run --filter @qqbot/bot build:watch",
    "build:admin": "bun run --filter @qqbot/webui build",
    "debug": "bun run --filter @qqbot/bot debug",
    "typecheck": "tsc -b",
    "type-check": "tsc -b",
    "lint": "biome check packages/*/src",
    "lint:fix": "biome check --write packages/*/src",
    "format": "biome format --write packages/*/src",
    "smoke-test": "NO_FILE_LOG=1 bun run packages/bot/src/cli/smoke-test.ts",
    "cluster:e2e": "bun run --filter @qqbot/bot cluster:e2e",
    "cluster:e2e:claude": "bun run --filter @qqbot/bot cluster:e2e:claude",
    "cluster:e2e:gemini": "bun run --filter @qqbot/bot cluster:e2e:gemini",
    "cluster:e2e:codex": "bun run --filter @qqbot/bot cluster:e2e:codex",
    "cluster-tickets:sync": "bun run --filter @qqbot/bot cluster-tickets:sync",
    "test": "bun test packages/bot",
    "test:network": "NETWORK_TESTS=1 bun test packages/bot",
    "prepare": "husky"
  },
  "keywords": ["qqbot", "qq", "bot", "milky", "onebot", "satori"],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "concurrently": "^9.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "jsonrepair": "^3.14.0"
  }
}
