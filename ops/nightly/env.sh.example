# ops/nightly/env.sh.example
#
# Copy this file to env.sh (in the same directory) and fill in your real values.
# env.sh is listed in .gitignore and will NOT be committed to the repository.
#
# NOTE: The correct variable name is ANTHROPIC_API_KEY (not the legacy token var).

# MiniMax Anthropic-compatible endpoint and model
export ANTHROPIC_BASE_URL="https://api.minimaxi.com/anthropic"
export ANTHROPIC_MODEL="MiniMax-M2.7"

# Your MiniMax API key — replace the placeholder with your real key
export ANTHROPIC_API_KEY="REPLACE_WITH_YOUR_MINIMAX_API_KEY"

# Optional: override the claude CLI binary path (default: "claude")
# export CLAUDE_CLI="/usr/local/bin/claude"
